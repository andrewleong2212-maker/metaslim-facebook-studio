# This file contains names and non-secret placeholders only.
# Copy real values into an untracked local environment file or server secret store.

# Application
APP_ENV=development
APP_URL=http://localhost:3000
APP_TIMEZONE=Asia/Kuala_Lumpur
LOG_LEVEL=info
LOG_REDACTION_ENABLED=true

# Public Supabase configuration (safe to expose only with correctly tested RLS)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-public-anon-key

# Server-only Supabase configuration - never expose to browser bundles
SUPABASE_SERVICE_ROLE_KEY=

# STEP 3 intentionally has no OpenAI, Facebook API, or Google Trends credentials.
