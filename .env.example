# This file contains names and non-secret placeholders only.
# Copy values into an untracked local environment file when implementation begins.

# Application
APP_ENV=development
APP_URL=http://localhost:3000
APP_TIMEZONE=Asia/Kuala_Lumpur
LOG_LEVEL=info
LOG_REDACTION_ENABLED=true

# Public Supabase configuration (safe to expose only with correctly tested RLS)
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=replace-with-public-anon-key

# Server-only Supabase configuration - never expose to browser bundles
SUPABASE_SERVICE_ROLE_KEY=replace-in-server-secret-store
SUPABASE_DATABASE_URL=replace-in-server-secret-store

# OpenAI - server only; leave disabled until Phase 2 approval
OPENAI_ENABLED=false
OPENAI_API_KEY=replace-in-server-secret-store
OPENAI_MODEL=replace-with-approved-model
OPENAI_MONTHLY_BUDGET_CENTS=0

# Facebook - server only; leave disabled until permissions and App Review are approved
FACEBOOK_ENABLED=false
FACEBOOK_APP_ID=replace-with-approved-app-id
FACEBOOK_APP_SECRET=replace-in-server-secret-store
FACEBOOK_GRAPH_API_VERSION=replace-with-approved-version
FACEBOOK_REDIRECT_URI=http://localhost:3000/api/integrations/facebook/callback

# Trends provider - no provider selected in STEP 1
TRENDS_PROVIDER=disabled
TRENDS_API_KEY=replace-in-server-secret-store-if-approved

# Netlify / background tasks - server only
BACKGROUND_JOB_SIGNING_SECRET=replace-in-server-secret-store
CRON_SIGNING_SECRET=replace-in-server-secret-store

# Optional observability - must be configured with PII redaction
OBSERVABILITY_ENABLED=false
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
